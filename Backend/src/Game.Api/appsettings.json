{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "https://perguntinhas-rosy.vercel.app"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "perguntinhas",
    "Audience": "perguntinhas-app",
    "LifetimeMinutes": 60
  },
  "GoogleAuth": {
    "ClientId": ""
  },
  "Rewards": {
    "IntelligentSelectionEnabled": true,
    "CatalogResource": "reward-templates.v1.json"
  }
}
